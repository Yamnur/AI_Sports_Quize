# Copy this file to ".env" and fill in your real key.
# Never commit your real .env file to version control.

# --- Choose your LLM provider: "groq" (free, no billing needed) or "openai" ---
LLM_PROVIDER=groq

# --- Groq (default, free) ---
# Get a free key at https://console.groq.com/keys -- no credit card required.
GROQ_API_KEY=gsk_your-groq-api-key-here
GROQ_MODEL=llama-3.1-8b-instant

# --- OpenAI (paid, only needed if LLM_PROVIDER=openai) ---
# https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-your-key-here
OPENAI_MODEL=gpt-4o-mini
